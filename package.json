{
  "name": "evolution",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "verify": "pnpm build:check && pnpm test",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:gh-pages": "tsc && vite build --outDir gh-pages --base=/evolution/",
    "build:check": "tsc --noEmit",
    "verify:types": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^3.2.4"
  }
}
